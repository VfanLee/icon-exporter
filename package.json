{
  "name": "icon-forge",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm build:shared && pnpm build:api && pnpm build:web",
    "build:api": "pnpm --filter @icon-forge/api build",
    "build:shared": "pnpm --filter @icon-forge/shared build",
    "build:web": "pnpm --filter @icon-forge/web build",
    "dev:api": "pnpm --filter @icon-forge/api dev",
    "dev:shared": "pnpm --filter @icon-forge/shared dev",
    "dev:web": "pnpm --filter @icon-forge/web dev",
    "format": "prettier --write .",
    "lint": "pnpm -r lint"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "prettier": "^3.4.2",
    "prettier-plugin-packagejson": "^3.0.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.62.0"
  },
  "packageManager": "pnpm@11.9.0"
}
